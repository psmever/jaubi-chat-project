{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@jaubi-chat/shared": ["../../packages/shared/dist/index.d.ts"],
      "@jaubi-chat/api-contract": ["../../packages/api-contract/dist/index.d.ts"]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "noEmit": false,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
