        "@nestjs/websockets": "11.1.27",
        "@prisma/adapter-mariadb": "7.8.0",
        "@prisma/client": "7.8.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "dotenv": "17.4.2",
