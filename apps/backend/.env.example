# Backend environment example.
# Copy this file to `apps/backend/.env` for local backend development.

# Application runtime environment.
NODE_ENV=local

# Prefix applied to all backend API routes.
GLOBAL_PREFIX=api

# Main MariaDB database used by the NestJS application.
DATABASE_URL=mysql://jaubi_chat:jaubi_chat@localhost:23306/jaubi_chat

# Prisma Migrate development-only shadow database.
# `prisma migrate dev` uses this database to validate migrations before
# applying them to DATABASE_URL.
SHADOW_DATABASE_URL=mysql://jaubi_chat:jaubi_chat@localhost:23306/jaubi_chat_shadow

# HTTP port for the NestJS backend.
BACKEND_PORT=4001

# Allowed browser origin for local CORS requests.
# Add more handling later if the app needs multiple local origins.
BACKEND_CORS_ORIGIN=http://localhost:3002

# JWT secrets for local development.
# Use `pnpm jwt:generate` to create unique, long random values in `apps/backend/.env`.
JWT_ACCESS_SECRET=local-access-secret-at-least-32-characters
JWT_REFRESH_SECRET=local-refresh-secret-at-least-32-characters
