{
  "name": "jaubi-chat-project",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": "11.6.0"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "docker:build": "docker-compose build",
    "docker:pull": "docker-compose pull",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:ps": "docker-compose ps",
    "docker:logs": "docker-compose logs -f",
    "docker:reset": "docker-compose down -v --remove-orphans",
    "db:up": "docker-compose up -d mariadb",
    "db:down": "docker-compose stop mariadb",
    "db:restart": "docker-compose restart mariadb",
    "db:ps": "docker-compose ps mariadb",
    "db:logs": "docker-compose logs -f mariadb",
    "db:init": "sh scripts/db-init.sh",
    "db:wait": "sh scripts/db-wait.sh",
    "db:reset": "sh scripts/db-reset.sh",
    "backend:dev": "pnpm --filter @jaubi-chat/backend dev",
    "backend:build": "pnpm --filter @jaubi-chat/backend build",
    "backend:typecheck": "pnpm --filter @jaubi-chat/backend typecheck",
    "backend:prisma:generate": "pnpm --filter @jaubi-chat/backend prisma:generate",
    "backend:prisma:migrate": "pnpm --filter @jaubi-chat/backend prisma:migrate"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
