# Root environment example.
# This file is used by local Docker Compose commands.
# Copy this file to `.env` in the repository root when you want to override
# the local MariaDB container settings.

# Host port exposed by the local MariaDB container.
# MariaDB still listens on 3306 inside the container.
MARIADB_PORT=23306

# Local root password for the MariaDB container.
# This is for local development only.
MARIADB_ROOT_PASSWORD=root

# Default application database created for local development.
MARIADB_DATABASE=jaubi_chat

# Default application database user.
MARIADB_USER=jaubi_chat

# Password for the default application database user.
MARIADB_PASSWORD=jaubi_chat

# Convenience connection string for local tools.
# The backend has its own env file at `apps/backend/.env`.
DATABASE_URL=mysql://jaubi_chat:jaubi_chat@localhost:23306/jaubi_chat
