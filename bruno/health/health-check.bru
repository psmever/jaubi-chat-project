meta {
  name: Health Check
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/health
  body: none
  auth: none
}

tests {
  test("returns HTTP 200", function () {
    expect(res.getStatus()).to.equal(200);
  });

  test("returns an ok status", function () {
    expect(res.getBody()).to.eql({ status: "ok" });
  });
}
